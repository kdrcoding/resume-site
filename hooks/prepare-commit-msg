#!/bin/sh
# Strip Cursor Agent co-author trailers before the commit is created.
# Cursor can inject: Co-authored-by: Cursor <cursoragent@cursor.com>

MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0

TMP="${MSG_FILE}.nocursor"
grep -vi \
  -e 'cursoragent@cursor.com' \
  -e 'co-authored-by:.*cursor' \
  -e 'made-with:.*cursor' \
  "$MSG_FILE" > "$TMP" && mv "$TMP" "$MSG_FILE"

exit 0
